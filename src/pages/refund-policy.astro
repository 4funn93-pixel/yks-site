---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Refund Policy — YKS" description="30-day no-questions money-back guarantee on all paid printables." canonical="/refund-policy">
  <div class="max-w-2xl mx-auto px-6 py-14">
    <h1 class="text-4xl tracking-tight font-semibold mb-6">Refund Policy</h1>
    
    <div class="prose prose-invert">
      <p><strong>30-day 100% money-back guarantee.</strong></p>
      
      <p>If any paid guide does not deliver clear, actionable value within 30 days of purchase, email us from the address used to buy and we will refund you in full — no questions, no hassle.</p>

      <p>We are confident in our work. The guarantee exists because we want every buyer to feel completely safe taking action.</p>

      <p class="text-sm text-text-subtle mt-8">Digital delivery makes refunds rare, but our reputation matters more than any single sale.</p>
    </div>
  </div>
</BaseLayout>
