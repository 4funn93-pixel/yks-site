---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config/site';
---

<BaseLayout title="Contact — YKS" description="Questions about printables, partnerships, or custom systems? Reach out. We read every message." canonical="/contact">
  <div class="max-w-xl mx-auto px-6 pt-16 pb-24">
    <div class="eyebrow mb-3">Contact</div>
    <h1 class="text-4xl md:text-5xl mb-3">Get in touch</h1>
    <p class="text-text-muted leading-relaxed mb-10">For guide support, bulk licensing, or press — use the form below, or email <a href={`mailto:${SITE.email}`} class="text-primary underline underline-offset-4">{SITE.email}</a>. We typically reply within a day.</p>

    <form
      name="contact"
      method="POST"
      action="/thank-you?type=contact"
      data-netlify="true"
      data-netlify-honeypot="bot-field"
      class="space-y-4"
    >
      <input type="hidden" name="form-name" value="contact" />
      <!-- Honeypot: bots fill this hidden field; real users don't. Submissions with it set are dropped. -->
      <p class="hidden">
        <label>Don't fill this out if you're human: <input name="bot-field" /></label>
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <input type="text" name="name" aria-label="Your name" placeholder="Your name" required class="bg-bg-card border border-border focus:border-primary outline-none px-5 py-3.5 rounded-2xl transition-colors" />
        <input type="email" name="email" aria-label="Email address" placeholder="Email address" required class="bg-bg-card border border-border focus:border-primary outline-none px-5 py-3.5 rounded-2xl transition-colors" />
      </div>

      <textarea name="message" rows="6" aria-label="Message" placeholder="How can we help?" required class="w-full bg-bg-card border border-border focus:border-primary outline-none px-5 py-3.5 rounded-2xl transition-colors"></textarea>

      <button type="submit" class="btn btn-primary w-full sm:w-auto px-10 py-3.5">Send message</button>
    </form>

    <div class="mt-10 text-xs text-text-subtle">For premium-pack order issues, check your email receipt or reply directly to the delivery email.</div>
  </div>
</BaseLayout>
