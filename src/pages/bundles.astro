---
/**
 * Premium Packs page — the "own the set once" rung of the ladder.
 *
 * The value ladder is intentionally simple and non-cannibalising:
 *   Free library/tools  →  single premium guide  →  this pack (own the set)
 *   →  YKS Pro (everything + future + editable, ongoing).
 *
 * Packs are curated bundles of the *real* premium guides at a discount vs
 * buying them one at a time. Editable in the CMS at /admin → "Premium Packs"
 * (src/config/bundles.data.json). Each pack's checkoutUrl is set after creating
 * the product in Lemon Squeezy; until then the CTA shows a "coming soon" state.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import bundlesData from '../config/bundles.data.json';

const bundles = bundlesData.bundles;
const guides = await getCollection('guides', ({ data }) => !data.draft);
---

<BaseLayout
  title="Premium Packs | YKS"
  description="Own the premium guides as a discounted set. A complete paper productivity system plus the full neurodivergent daily-living guide — one-time purchase, lifetime updates. The whole free library stays free."
  canonical="/bundles"
>
  <div class="max-w-5xl mx-auto px-6 pt-10 pb-28">
    <div class="max-w-2xl mb-10">
      <div class="eyebrow mb-3">Premium packs</div>
      <h1 class="text-5xl md:text-6xl">Own the set, once.</h1>
      <p class="mt-4 text-lg text-text-muted leading-relaxed">
        Every guide page is free to read. The packs bundle the <strong class="text-text">premium</strong>
        guides — the deep, complete systems — into print-ready PDFs at a discount versus buying
        them one at a time. One-time purchase, yours forever, lifetime updates included.
      </p>
    </div>

    <div class="space-y-10">
      {bundles.map(bundle => {
        const bundleGuides = guides.filter(g => bundle.guides.includes(g.data.slug));
        return (
          <div class="bg-bg-card border border-border rounded-3xl p-8 md:p-10">
            <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6 mb-8">
              <div>
                <div class="inline-flex items-center gap-2 mb-3">
                  <span class="badge badge-paid">PACK</span>
                  <span class="text-xs text-text-subtle">Save ${bundle.savings} vs buying separately</span>
                </div>
                <h2 class="text-3xl font-semibold tracking-tight mb-2">{bundle.name}</h2>
                <p class="text-text-muted max-w-lg">{bundle.description}</p>
              </div>
              <div class="text-right shrink-0">
                <div class="flex items-baseline justify-end gap-2 mb-1">
                  <span class="text-4xl font-semibold tabular-nums">${bundle.price}</span>
                  <span class="text-text-subtle line-through">${bundle.original}</span>
                </div>
                <div class="text-xs text-text-subtle">One-time · Instant delivery · Lifetime updates</div>
              </div>
            </div>

            <div class="grid md:grid-cols-2 gap-8 mb-8">
              <div>
                <div class="font-medium mb-3 flex items-center gap-2"><span>📦</span> What's included</div>
                <ul class="space-y-2 text-sm">
                  {bundle.includes.map(item => (
                    <li class="flex gap-2"><span class="text-primary shrink-0">✓</span> <span class="text-text-muted">{item}</span></li>
                  ))}
                </ul>
              </div>
              <div>
                <div class="font-medium mb-3">Guides in this pack</div>
                <div class="space-y-3">
                  {bundleGuides.map(g => (
                    <a href={`/guides/${g.data.slug}`} class="block text-sm text-text-muted hover:text-primary transition-colors">
                      {g.data.title} <span class="text-text-subtle">— normally ${g.data.price}</span>
                    </a>
                  ))}
                </div>
              </div>
            </div>

            <div class="border-t border-border pt-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
              <div class="text-[11px] text-text-subtle">Fair, case-by-case refunds · Delivered via Lemon Squeezy · Includes all future updates</div>
              {bundle.checkoutUrl ? (
                <a href={bundle.checkoutUrl} class="lemonsqueezy-button btn btn-primary px-8 whitespace-nowrap shrink-0">{bundle.cta}</a>
              ) : (
                <div class="text-right shrink-0">
                  <a href="/#lead-magnet" class="btn btn-primary px-8 whitespace-nowrap">Get notified at launch →</a>
                  <p class="text-[10px] text-text-subtle mt-1.5 font-mono">PACK CHECKOUT LAUNCHING SOON</p>
                </div>
              )}
            </div>
          </div>
        );
      })}
    </div>

    <!-- ladder context: where packs sit vs single guides and Pro -->
    <div class="mt-12 grid sm:grid-cols-2 gap-4">
      <div class="surface-card p-6">
        <div class="eyebrow mb-2">Just want one?</div>
        <p class="text-sm text-text-muted leading-relaxed">Every premium guide is also sold on its own. Read the free guide pages and buy only the deep system you want.</p>
        <a href="/guides" class="mt-3 inline-flex items-center gap-1.5 font-mono text-[11px] tracking-wider text-primary hover:underline">BROWSE GUIDES <span aria-hidden="true">→</span></a>
      </div>
      <div class="surface-card p-6 border-primary/30">
        <div class="eyebrow mb-2">Want everything + what's next?</div>
        <p class="text-sm text-text-muted leading-relaxed"><strong class="text-text">YKS Pro</strong> includes every premium guide, every future one, editable source files and monthly drops — ongoing.</p>
        <a href="/pro" class="mt-3 inline-flex items-center gap-1.5 font-mono text-[11px] tracking-wider text-primary hover:underline">SEE YKS PRO <span aria-hidden="true">→</span></a>
      </div>
    </div>

    <p class="mt-10 text-center text-sm text-text-muted">
      The entire free library and all tools stay free, forever — <a href="/guides" class="text-primary underline underline-offset-4">no signup</a>.
    </p>
  </div>
</BaseLayout>
