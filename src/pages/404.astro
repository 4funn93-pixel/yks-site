---
import BaseLayout from '../layouts/BaseLayout.astro';
import Mascot from '../components/Mascot.astro';
---

<BaseLayout
  title="Page not found"
  description="That page doesn't exist. Browse the free library or search for what you need."
  noindex={true}
>
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-grid pointer-events-none"></div>
    <div class="absolute -top-40 left-1/2 -translate-x-1/2 w-[600px] h-[360px] glow-accent pointer-events-none"></div>

    <div class="relative max-w-2xl mx-auto px-6 py-32 text-center">
      <Mascot pose="sleep" class="w-24 h-24 mx-auto mb-2 text-primary" title="Sprout, asleep on the job" />
      <div class="font-display font-bold text-[clamp(5rem,18vw,11rem)] leading-none accent-text">404</div>
      <h1 class="text-3xl md:text-4xl mt-2 mb-4">This page wandered off.</h1>
      <p class="text-text-muted leading-relaxed mb-9 max-w-md mx-auto">
        The page you're after doesn't exist (or moved). Let's get you back to something useful.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/guides" class="btn btn-primary px-8 py-4">Browse the library</a>
        <a href="/search" class="btn btn-secondary px-7 py-4">Search the site</a>
      </div>
      <div class="mt-10 font-mono text-[11px] tracking-wider text-text-subtle">
        <a href="/" class="hover:text-primary">HOME</a>
        <span class="text-border mx-2">/</span>
        <a href="/blog" class="hover:text-primary">BLOG</a>
        <span class="text-border mx-2">/</span>
        <a href="/faq" class="hover:text-primary">FAQ</a>
      </div>
    </div>
  </section>
</BaseLayout>
