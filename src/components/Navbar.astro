---
/**
 * Clean sticky navbar for YKS printables
 * - Logo + nav (Guides first, Bundles/Packs de-emphasized)
 * - Theme toggle (Alpine powered, system default)
 * - Mobile hamburger with slide-in panel
 * - CTAs: Browse Guides + prominent Get Free
 */
---

<header 
  x-data="{ 
    mobileOpen: false, 
    scrolled: false 
  }"
  x-init="
    window.addEventListener('scroll', () => { scrolled = window.scrollY > 20 });
    // Close mobile on escape
    document.addEventListener('keydown', e => { if (e.key === 'Escape') mobileOpen = false });
  "
  class="sticky top-0 z-50 border-b transition-all glass"
  :class="scrolled ? 'border-[var(--color-border)]' : 'border-transparent'"
>
  <nav class="mx-auto max-w-7xl px-6 flex h-[68px] items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 group" aria-label="YKS home">
      <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: var(--gradient-mark)">
        <span class="text-[#0a0a0b] text-[13px] font-bold tracking-tight">Y</span>
      </div>
      <span class="font-display font-bold text-lg tracking-[-0.04em] group-hover:text-primary transition-colors">
        YKS<span class="text-text-subtle font-normal"> / printables</span>
      </span>
    </a>

    <!-- Desktop Navigation -->
    <div class="hidden md:flex items-center gap-9 text-sm font-medium text-text-muted">
      <a href="/guides" class="hover:text-text transition-colors">Guides</a>
      <a href="/tools" class="hover:text-text transition-colors">Tools</a>
      <a href="/blog" class="hover:text-text transition-colors">Blog</a>
      <a href="/about" class="hover:text-text transition-colors">About</a>
      <a href="/pro" class="hover:text-primary transition-colors text-primary/90">Pro</a>
    </div>

    <!-- Actions -->
    <div class="flex items-center gap-3">
      <!-- Search -->
      <a
        href="/search"
        class="w-10 h-10 rounded-full flex items-center justify-center text-text-muted hover:bg-surface hover:text-text border border-border transition-all"
        aria-label="Search"
        title="Search"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11a6 6 0 11-12 0 6 6 0 0112 0z" />
        </svg>
      </a>

      <!-- Theme Toggle (Alpine + localStorage + system) -->
      <button 
        @click=" 
          const isDark = !document.documentElement.classList.contains('light');
          if (isDark) {
            document.documentElement.classList.add('light');
            localStorage.setItem('theme', 'light');
          } else {
            document.documentElement.classList.remove('light');
            localStorage.setItem('theme', 'dark');
          }
        "
        class="w-10 h-10 rounded-full flex items-center justify-center text-text-muted hover:bg-surface hover:text-text border border-border transition-all active:scale-95"
        aria-label="Toggle dark/light theme"
        title="Toggle theme"
      >
        <!-- Icons via inline SVG for zero deps -->
        <svg x-show="!document.documentElement.classList.contains('light')" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
        <svg x-show="document.documentElement.classList.contains('light')" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
        </svg>
      </button>

      <!-- Desktop CTAs -->
      <div class="hidden sm:flex items-center gap-2.5">
        <a href="/guides" class="btn btn-secondary text-sm px-5 py-2">Browse Guides</a>
        <a href="/tools" class="btn btn-primary text-sm px-5 py-2">Try a Free Tool</a>
      </div>

      <!-- Mobile Hamburger -->
      <button 
        @click="mobileOpen = !mobileOpen"
        class="md:hidden w-10 h-10 flex items-center justify-center text-text-muted hover:text-text border border-border rounded-full"
        aria-label="Toggle menu"
        :aria-expanded="mobileOpen"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" :class="{ 'hidden': mobileOpen }" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" :class="{ 'hidden': !mobileOpen }" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Slide-in Menu -->
  <div 
    x-show="mobileOpen"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    class="md:hidden fixed inset-0 z-50 bg-black/70 backdrop-blur-sm"
    @click="mobileOpen = false"
  >
    <div 
      @click.stop
      class="absolute right-0 top-0 h-full w-4/5 max-w-xs bg-bg-elevated border-l border-border p-8 flex flex-col"
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="translate-x-full"
      x-transition:enter-end="translate-x-0"
    >
      <div class="flex justify-between items-center mb-10">
        <span class="font-semibold text-lg">Menu</span>
        <button @click="mobileOpen = false" class="text-text-muted">✕</button>
      </div>

      <div class="flex flex-col gap-6 text-lg font-medium">
        <a href="/guides" class="py-1 hover:text-primary" @click="mobileOpen = false">Guides</a>
        <a href="/tools" class="py-1 hover:text-primary" @click="mobileOpen = false">Free Tools</a>
        <a href="/blog" class="py-1 hover:text-primary" @click="mobileOpen = false">Blog &amp; Insights</a>
        <a href="/about" class="py-1 hover:text-primary" @click="mobileOpen = false">Our Story</a>
        <a href="/faq" class="py-1 hover:text-primary" @click="mobileOpen = false">FAQ</a>
        <a href="/search" class="py-1 hover:text-primary" @click="mobileOpen = false">Search</a>
        <a href="/pro" class="py-1 hover:text-primary text-primary" @click="mobileOpen = false">YKS Pro</a>
        <a href="/bundles" class="py-1 hover:text-primary text-sm text-text-subtle" @click="mobileOpen = false">Premium Packs</a>
        <div class="h-px bg-border my-2"></div>
        <a href="/guides" class="btn btn-secondary justify-center" @click="mobileOpen = false">Browse the library</a>
        <a href="/tools" class="btn btn-primary justify-center" @click="mobileOpen = false">Try a free tool</a>
      </div>

      <div class="mt-auto pt-8 text-xs text-text-subtle">
        Practical printables for habits, focus &amp; productivity.
      </div>
    </div>
  </div>
</header>

<!-- Initialize theme on first load (dark-first; opt into light) -->
<script>
  (function initTheme() {
    const stored = localStorage.getItem('theme');
    if (stored === 'light') {
      document.documentElement.classList.add('light');
    } else {
      document.documentElement.classList.remove('light');
    }
  })();
</script>
