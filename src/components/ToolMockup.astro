---
/**
 * ToolMockup — on-brand SVG "screenshot" of a tool inside a browser frame.
 * Renders the dark-first app UI (consistent regardless of page theme, like a
 * real screenshot) with the acid-lime accent. No raster images, no stock.
 *
 * variant: 'habit' | 'focus' | 'planner' | 'breath' | 'braindump' | 'breakdown'
 * 'planner' is a faded "coming soon" frame.
 */
interface Props {
  variant: 'habit' | 'focus' | 'planner' | 'breath' | 'braindump' | 'breakdown';
  label?: string;
  class?: string;
}
const { variant, label, class: className = '' } = Astro.props;

// Fixed app palette (the tools are dark-first; the mockup is a snapshot).
const C = {
  frame: '#1a1a1f',
  bar: '#131316',
  screen: '#0e0e11',
  card: '#131316',
  border: '#26262c',
  primary: '#c7f73e',
  ink: '#101012',
  text: '#f4f4f5',
  muted: '#a1a1aa',
  subtle: '#71717a',
};

const addr = variant === 'focus' ? 'yks.site/tools/focus-timer'
  : variant === 'planner' ? 'yks.site/tools/weekly-planner'
  : variant === 'breath' ? 'yks.site/tools/breathing'
  : variant === 'braindump' ? 'yks.site/tools/brain-dump'
  : variant === 'breakdown' ? 'yks.site/tools/task-breakdown'
  : 'yks.site/tools/habit-tracker';

// habit grid: 1 = filled (lime), 0 = empty
const rows = [
  { y: 150, cells: [1, 1, 1, 0, 1, 1, 0], streak: '4' },
  { y: 196, cells: [1, 1, 0, 1, 1, 0, 0], streak: '2' },
  { y: 242, cells: [1, 0, 1, 1, 1, 1, 1], streak: '6' },
];
---

<div class={`tool-mockup ${className}`} role="img" aria-label={label || `${variant} tool preview`}>
  <svg viewBox="0 0 640 420" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto block">
    <!-- frame -->
    <rect x="1" y="1" width="638" height="418" rx="18" fill={C.frame} stroke={C.border} stroke-width="1.5" />
    <!-- top bar -->
    <path d={`M1 19 a18 18 0 0 1 18 -18 h602 a18 18 0 0 1 18 18 v34 h-638 z`} fill={C.bar} />
    <circle cx="26" cy="27" r="5" fill={C.subtle} opacity="0.6" />
    <circle cx="44" cy="27" r="5" fill={C.subtle} opacity="0.6" />
    <circle cx="62" cy="27" r="5" fill={C.primary} opacity="0.9" />
    <rect x="92" y="16" width="430" height="22" rx="11" fill={C.screen} stroke={C.border} stroke-width="1" />
    <text x="112" y="31" font-family="monospace" font-size="12" fill={C.subtle}>{addr}</text>
    <!-- screen -->
    <rect x="1" y="53" width="638" height="366" rx="0" fill={C.screen} />
    <rect x="1" y="402" width="638" height="17" rx="0" fill={C.screen} />

    {variant === 'habit' && (
      <g>
        <!-- header -->
        <text x="36" y="92" font-family="monospace" font-size="11" letter-spacing="2" fill={C.primary}>FREE INTERACTIVE TOOL</text>
        <text x="36" y="120" font-family="sans-serif" font-weight="700" font-size="26" fill={C.text}>Habit tracker</text>
        <!-- week completion bar -->
        <rect x="430" y="100" width="174" height="6" rx="3" fill={C.card} />
        <rect x="430" y="100" width="118" height="6" rx="3" fill={C.primary} />
        <text x="430" y="92" font-family="monospace" font-size="10" letter-spacing="1" fill={C.subtle}>WEEK 68%</text>

        <!-- day header -->
        {['M','T','W','T','F','S','S'].map((d, i) => (
          <text x={300 + i * 40} y="138" font-family="monospace" font-size="11" fill={C.subtle} text-anchor="middle">{d}</text>
        ))}
        <text x="592" y="138" font-family="monospace" font-size="10" fill={C.subtle} text-anchor="middle">🔥</text>

        {rows.map((row) => (
          <g>
            <rect x="36" y={row.y} width="20" height="20" rx="6" fill={C.card} stroke={C.border} />
            <rect x="64" y={row.y + 4} width="120" height="12" rx="6" fill={C.card} />
            {row.cells.map((on, i) => (
              on
                ? <rect x={284 + i * 40} y={row.y - 2} width="24" height="24" rx="7" fill={C.primary} />
                : <rect x={284 + i * 40} y={row.y - 2} width="24" height="24" rx="7" fill={C.screen} stroke={C.border} />
            ))}
            {row.cells.map((on, i) => (
              on ? <path d={`M${290 + i * 40} ${row.y + 10} l4 4 l8 -8`} stroke={C.ink} stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" /> : null
            ))}
            <text x="592" y={row.y + 14} font-family="sans-serif" font-weight="700" font-size="13" fill={C.primary} text-anchor="middle">{row.streak}</text>
          </g>
        ))}
      </g>
    )}

    {variant === 'focus' && (
      <g>
        <text x="320" y="100" font-family="monospace" font-size="11" letter-spacing="2" fill={C.primary} text-anchor="middle">FREE INTERACTIVE TOOL</text>
        <!-- ring -->
        <circle cx="320" cy="220" r="84" fill="none" stroke={C.card} stroke-width="10" />
        <circle cx="320" cy="220" r="84" fill="none" stroke={C.primary} stroke-width="10" stroke-linecap="round"
          stroke-dasharray="527" stroke-dashoffset="180" transform="rotate(-90 320 220)" />
        <text x="320" y="230" font-family="sans-serif" font-weight="700" font-size="46" fill={C.text} text-anchor="middle">24:59</text>
        <text x="320" y="255" font-family="monospace" font-size="11" letter-spacing="3" fill={C.primary} text-anchor="middle">IN FOCUS</text>
        <!-- stats -->
        <line x1="200" y1="340" x2="440" y2="340" stroke={C.border} />
        <text x="265" y="372" font-family="sans-serif" font-weight="700" font-size="22" fill={C.text} text-anchor="middle">3</text>
        <text x="265" y="390" font-family="monospace" font-size="9" letter-spacing="1" fill={C.subtle} text-anchor="middle">SESSIONS</text>
        <line x1="320" y1="352" x2="320" y2="384" stroke={C.border} />
        <text x="375" y="372" font-family="sans-serif" font-weight="700" font-size="22" fill={C.text} text-anchor="middle">75m</text>
        <text x="375" y="390" font-family="monospace" font-size="9" letter-spacing="1" fill={C.subtle} text-anchor="middle">FOCUSED</text>
      </g>
    )}

    {variant === 'breath' && (
      <g>
        <text x="320" y="100" font-family="monospace" font-size="11" letter-spacing="2" fill={C.primary} text-anchor="middle">FREE INTERACTIVE TOOL</text>
        <!-- breathing orb: concentric glow rings -->
        <circle cx="320" cy="222" r="96" fill="none" stroke={C.border} stroke-width="1.5" opacity="0.7" />
        <circle cx="320" cy="222" r="74" fill="none" stroke={C.primary} stroke-width="1.5" opacity="0.5" />
        <circle cx="320" cy="222" r="58" fill={C.primary} opacity="0.12" />
        <circle cx="320" cy="222" r="58" fill="none" stroke={C.primary} stroke-width="2.5" opacity="0.9" />
        <text x="320" y="216" font-family="monospace" font-size="11" letter-spacing="3" fill={C.primary} text-anchor="middle">BREATHE IN</text>
        <text x="320" y="244" font-family="sans-serif" font-weight="700" font-size="26" fill={C.text} text-anchor="middle">4</text>
        <!-- technique pills -->
        {['BOX','4-7-8','COHERENT'].map((t, i) => (
          <g>
            <rect x={196 + i * 86} y="340" width="76" height="24" rx="12" fill={i === 0 ? C.primary : C.card} stroke={C.border} />
            <text x={196 + 38 + i * 86} y="356" font-family="monospace" font-size="9" letter-spacing="1" fill={i === 0 ? C.ink : C.muted} text-anchor="middle">{t}</text>
          </g>
        ))}
      </g>
    )}

    {variant === 'braindump' && (
      <g>
        <text x="36" y="92" font-family="monospace" font-size="11" letter-spacing="2" fill={C.primary}>FREE INTERACTIVE TOOL</text>
        <text x="36" y="120" font-family="sans-serif" font-weight="700" font-size="26" fill={C.text}>Brain dump</text>

        <!-- capture bar -->
        <rect x="36" y="150" width="462" height="36" rx="18" fill={C.card} stroke={C.border} />
        <text x="54" y="173" font-family="sans-serif" font-size="13" fill={C.subtle}>What's rattling around?</text>
        <rect x="508" y="150" width="96" height="36" rx="18" fill={C.primary} />
        <text x="556" y="173" font-family="sans-serif" font-weight="700" font-size="13" fill={C.ink} text-anchor="middle">Dump it</text>

        <!-- triaged rows: each thought + an active bucket pill -->
        {[
          { y: 214, w: 250, active: 0 },
          { y: 256, w: 320, active: 1 },
          { y: 298, w: 200, active: 2 },
          { y: 340, w: 286, active: 0 },
        ].map((row) => (
          <g>
            <rect x="36" y={row.y} width="568" height="32" rx="10" fill={C.card} stroke={C.border} />
            <rect x="50" y={row.y + 11} width={row.w} height="10" rx="5" fill={C.screen} stroke={C.border} />
            {['Now','Next','Later'].map((p, i) => (
              <g>
                <rect x={388 + i * 70} y={row.y + 6} width="62" height="20" rx="10"
                  fill={i === row.active ? C.primary : C.screen} stroke={i === row.active ? C.primary : C.border} />
                <text x={388 + 31 + i * 70} y={row.y + 19} font-family="monospace" font-size="9" letter-spacing="0.5"
                  fill={i === row.active ? C.ink : C.subtle} text-anchor="middle">{p}</text>
              </g>
            ))}
          </g>
        ))}
      </g>
    )}

    {variant === 'breakdown' && (
      <g>
        <text x="36" y="92" font-family="monospace" font-size="11" letter-spacing="2" fill={C.primary}>FREE INTERACTIVE TOOL</text>
        <text x="36" y="120" font-family="sans-serif" font-weight="700" font-size="26" fill={C.text}>Break it down</text>

        <!-- progress bar -->
        <rect x="36" y="146" width="520" height="9" rx="4.5" fill={C.card} stroke={C.border} />
        <rect x="36" y="146" width="260" height="9" rx="4.5" fill={C.primary} />
        <text x="600" y="156" font-family="sans-serif" font-weight="700" font-size="13" fill={C.text} text-anchor="end">50%</text>

        <!-- steps with checkboxes -->
        {[
          { y: 184, w: 300, done: true },
          { y: 230, w: 240, done: true },
          { y: 276, w: 330, done: false, start: true },
          { y: 322, w: 210, done: false },
        ].map((row) => (
          <g>
            <rect x="36" y={row.y} width="568" height="34" rx="10" fill={C.card} stroke={C.border} />
            {row.done
              ? <g><rect x="50" y={row.y + 7} width="20" height="20" rx="6" fill={C.primary} /><path d={`M55 ${row.y + 17} l4 4 l7 -7`} stroke={C.ink} stroke-width="2.6" fill="none" stroke-linecap="round" stroke-linejoin="round" /></g>
              : <rect x="50" y={row.y + 7} width="20" height="20" rx="6" fill={C.screen} stroke={C.border} stroke-width="2" />}
            <rect x="82" y={row.y + 12} width={row.w} height="10" rx="5" fill={row.done ? C.screen : C.border} />
            {row.start && (
              <g>
                <rect x="500" y={row.y + 8} width="78" height="18" rx="9" fill={C.primary} />
                <text x="539" y={row.y + 20} font-family="monospace" font-size="9" letter-spacing="0.5" fill={C.ink} text-anchor="middle">START HERE</text>
              </g>
            )}
          </g>
        ))}
      </g>
    )}

    {variant === 'planner' && (
      <g opacity="0.5">
        <text x="320" y="150" font-family="monospace" font-size="11" letter-spacing="2" fill={C.subtle} text-anchor="middle">COMING SOON</text>
        {[0,1,2,3,4].map((c) => (
          <rect x={70 + c * 102} y="180" width="86" height="120" rx="10" fill={C.card} stroke={C.border} />
        ))}
        {[0,1,2,3,4].map((c) => (
          <g>
            <rect x={82 + c * 102} y="196" width="50" height="8" rx="4" fill={C.border} />
            <rect x={82 + c * 102} y="216" width="62" height="6" rx="3" fill={C.screen} stroke={C.border} />
            <rect x={82 + c * 102} y="234" width="62" height="6" rx="3" fill={C.screen} stroke={C.border} />
          </g>
        ))}
      </g>
    )}
  </svg>
</div>

<style>
  .tool-mockup {
    border-radius: 18px;
    box-shadow: 0 30px 70px -28px rgba(0, 0, 0, 0.85);
    overflow: hidden;
    line-height: 0;
  }
</style>
</content>
