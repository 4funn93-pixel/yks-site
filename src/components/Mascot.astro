---
/**
 * Mascot — "Sprout", a minimal monoline character for YKS.
 * Geometric, single-weight strokes, inherits color via currentColor (default
 * usage colors it with the lime accent). A leaf sprout = growth / habits.
 *
 * pose: 'default' | 'wink' | 'sleep'
 * Keep it disciplined: monoline, accent color, no rainbow fills.
 */
interface Props {
  pose?: 'default' | 'wink' | 'sleep';
  class?: string;
  title?: string;
}
const { pose = 'default', class: className = '', title = 'Sprout, the YKS mascot' } = Astro.props;
---

<svg
  viewBox="0 0 64 64"
  class={className}
  fill="none"
  stroke="currentColor"
  stroke-width="2.4"
  stroke-linecap="round"
  stroke-linejoin="round"
  role="img"
  aria-label={title}
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- sprout: stem + leaf -->
  <path d="M32 16 V10" />
  <path d="M32 12 C36 8 42 9 43 5 C38 4 33 6 32 11" fill="currentColor" stroke="none" />
  <!-- head -->
  <rect x="14" y="16" width="36" height="34" rx="12" />

  {pose === 'default' && (
    <g>
      <circle cx="25" cy="31" r="2.4" fill="currentColor" stroke="none" />
      <circle cx="39" cy="31" r="2.4" fill="currentColor" stroke="none" />
      <path d="M26 39 C29 43 35 43 38 39" />
    </g>
  )}

  {pose === 'wink' && (
    <g>
      <path d="M22.5 31 C24 29 26 29 27.5 31" />
      <circle cx="39" cy="31" r="2.4" fill="currentColor" stroke="none" />
      <path d="M26 39 C29 43 35 43 38 40" />
    </g>
  )}

  {pose === 'sleep' && (
    <g>
      <path d="M22.5 32 C24 30 26 30 27.5 32" />
      <path d="M36.5 32 C38 30 40 30 41.5 32" />
      <path d="M29 40 C31 38.5 33 38.5 35 40" />
      <!-- zzz -->
      <path d="M50 20 h6 l-6 6 h6" stroke-width="2" />
      <path d="M57 12 h4 l-4 4 h4" stroke-width="1.8" />
    </g>
  )}

  <!-- little feet -->
  <path d="M24 50 v3" />
  <path d="M40 50 v3" />
</svg>
</content>
