---
/**
 * Mascot — "Smallz", the YKS caveman who's wild about guides.
 * Monoline, single-weight strokes, inherits color via currentColor (default
 * usage colors it with the lime accent). Spiky hair + heavy unibrow + a tusk
 * + a toothy grin read as a friendly caveman at any size. A clean line-icon
 * stand-in for the full-color hero character in MascotPeek.astro.
 *
 * pose: 'default' | 'wink' | 'sleep'
 * Keep it disciplined: monoline, accent color, no rainbow fills.
 */
interface Props {
  pose?: 'default' | 'wink' | 'sleep';
  class?: string;
  title?: string;
}
const { pose = 'default', class: className = '', title = 'Smallz, the YKS mascot' } = Astro.props;
---

<svg
  viewBox="0 0 64 64"
  class={className}
  fill="none"
  stroke="currentColor"
  stroke-width="2.4"
  stroke-linecap="round"
  stroke-linejoin="round"
  role="img"
  aria-label={title}
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- spiky caveman hair -->
  <path d="M15 27 L17 14 L22 23 L26 11 L31 22 L36 11 L41 23 L46 14 L49 27" />
  <!-- head + heavy jaw -->
  <path d="M15 27 C13 41 17 49 24 52 C29 54 35 54 40 52 C47 49 51 41 49 27" />
  <!-- heavy unibrow -->
  <path d="M21 31 C25 28.5 28 29 32 29.5 C36 29 39 28.5 43 31" stroke-width="2.9" />

  {pose === 'default' && (
    <g>
      <circle cx="26" cy="35.5" r="2.3" fill="currentColor" stroke="none" />
      <circle cx="38" cy="35.5" r="2.3" fill="currentColor" stroke="none" />
      <!-- grin -->
      <path d="M25.5 43 C29 47 35 47 39 43" />
      <!-- tusk -->
      <path d="M27 45 C24.5 42 25 39 26.5 37" />
    </g>
  )}

  {pose === 'wink' && (
    <g>
      <path d="M23.5 35.5 C25 33.5 27 33.5 28.5 35.5" />
      <circle cx="38" cy="35.5" r="2.3" fill="currentColor" stroke="none" />
      <path d="M25.5 43 C29 47 35 47 39 42.5" />
      <path d="M27 45 C24.5 42 25 39 26.5 37" />
    </g>
  )}

  {pose === 'sleep' && (
    <g>
      <path d="M23.5 36 C25 34 27 34 28.5 36" />
      <path d="M35.5 36 C37 34 39 34 40.5 36" />
      <path d="M29 44 C31 42.5 33 42.5 35 44" />
      <!-- zzz -->
      <path d="M50 22 h6 l-6 6 h6" stroke-width="2" />
      <path d="M57 14 h4 l-4 4 h4" stroke-width="1.8" />
    </g>
  )}

  <!-- neck / shoulders -->
  <path d="M25 52 v3" />
  <path d="M39 52 v3" />
</svg>
