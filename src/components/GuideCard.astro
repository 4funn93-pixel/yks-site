---
/**
 * Premium GuideCard — Used on homepage featured + /guides grid
 * Handles free/paid distinction, beautiful hover, accessible
 */
import type { CollectionEntry } from 'astro:content';

export interface Props {
  guide: CollectionEntry<'guides'>;
  featured?: boolean;
}

const { guide, featured = false } = Astro.props;
const { data } = guide;

const isProOnly = data.proOnly;
const isFree = !isProOnly && (data.isFree || data.price === 0);
const priceDisplay = isProOnly ? 'PRO' : isFree ? 'FREE' : `$${data.price}`;
const priceClass = isProOnly ? 'badge-pro' : isFree ? 'badge-free' : 'badge-paid';

const coverSrc = data.coverImage?.src || '/images/guides/canva-3d-cover.svg';
---

<a 
  href={`/guides/${data.slug}`}
  class="guide-card group block overflow-hidden focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 focus:ring-offset-bg"
  aria-label={`View ${data.title} — ${isFree ? 'Free' : `$${data.price}`}`}
>
  <!-- Cover -->
  <div class="relative aspect-[4/3] overflow-hidden bg-surface">
    <img 
      src={coverSrc} 
      alt={data.coverImage?.alt || data.title}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
      loading={featured ? "eager" : "lazy"}
      width="600"
      height="450"
    />
    <!-- Gradient overlay for legibility + depth -->
    <div class="absolute inset-x-0 bottom-0 h-2/3 bg-gradient-to-t from-black/85 via-black/40 to-transparent"></div>

    <!-- Badges -->
    <div class="absolute top-3.5 left-3.5 flex gap-2">
      <span class={`badge ${priceClass}`}>{priceDisplay}</span>
      {!isProOnly && data.highResPdf && <span class="badge badge-pro">Hi-res in Pro</span>}
      {data.featured && <span class="badge bg-primary text-[#0a0a0b] border-primary">Featured</span>}
    </div>
  </div>

  <!-- Content -->
  <div class="p-6">
    <div class="flex items-start justify-between gap-3 mb-3">
      <span class="text-[10px] font-mono tracking-[1.5px] text-primary/80 uppercase">{data.category}</span>
    </div>

    <h3 class="font-semibold text-[17px] leading-tight tracking-[-0.3px] line-clamp-2 mb-2.5 group-hover:text-primary transition-colors">
      {data.title}
    </h3>

    <p class="text-sm text-text-muted line-clamp-3 leading-snug mb-5">
      {data.description}
    </p>

    <!-- Meta row -->
    <div class="flex items-center justify-between text-xs">
      <div class="flex items-center gap-2 text-text-subtle">
        <span>{data.readingTime}</span>
        <span class="text-border" aria-hidden="true">•</span>
        <span>{data.tags[0]}</span>
      </div>

      <span class="inline-flex items-center gap-1 text-primary font-medium group-hover:gap-1.5 transition-all text-xs">
        {isFree ? 'Get Free' : 'View Details'} 
        <span aria-hidden="true">→</span>
      </span>
    </div>
  </div>
</a>
