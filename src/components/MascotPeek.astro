---
/**
 * MascotPeek — "Smallz", the YKS caveman, as a homepage corner buddy.
 *
 * Uses the exact character artwork (src/assets/Smallz1.png → background removed +
 * pupils blanked to sclera white → public/images/mascot/smallz.png). The pupils
 * are re-drawn as an SVG overlay sitting in the same coordinate space as the
 * image (viewBox matches the PNG's natural 741×1056), so at rest he looks
 * identical to the source art, and the pupils glance toward the cursor.
 *
 * Behavior:
 *  - Peeks in from the bottom-right: slides up shortly after load (always
 *    visible, even where scroll events don't fire), then peeks higher as you
 *    scroll down the page.
 *  - Eyes follow the cursor (mousemove — fires reliably here, unlike scroll).
 *  - Click him → speech bubble with a rotating tip + a little wave. Click again
 *    or ✕ to hide.
 *  - Respects prefers-reduced-motion.
 *
 * Registration follows the site's is:inline Alpine pattern (plain JS, so the
 * alpine:init listener is in place before Alpine boots).
 */
---

<div
  id="mascot-peek"
  x-data="mascotPeek"
  x-cloak
  class="hidden md:block fixed bottom-0 right-4 lg:right-8 z-[120] w-[150px] select-none print:hidden"
  :class="peeked ? 'is-peeked' : ''"
  aria-live="polite"
>
  <!-- Speech bubble -->
  <div
    x-show="open"
    x-transition.scale.origin.bottom
    class="absolute bottom-[205px] right-0 w-[238px] mb-2 rounded-2xl border border-border bg-bg-card shadow-2xl p-4 text-left"
    x-cloak
  >
    <button
      @click="open = false"
      class="absolute top-2.5 right-2.5 text-text-subtle hover:text-text leading-none text-sm"
      aria-label="Close tip"
    >✕</button>
    <div class="eyebrow mb-1.5" x-text="tip.tag"></div>
    <p class="text-sm text-text leading-snug pr-3" x-text="tip.text"></p>
    <a
      :href="tip.href"
      class="mt-3 inline-flex items-center gap-1.5 font-mono text-[11px] tracking-wider text-primary hover:underline"
    >
      <span x-text="tip.cta"></span><span aria-hidden="true">→</span>
    </a>
    <!-- bubble tail -->
    <div class="absolute -bottom-2 right-10 w-4 h-4 rotate-45 bg-bg-card border-r border-b border-border"></div>
  </div>

  <!-- Smallz (exact artwork + tracking pupils) -->
  <button
    type="button"
    @click="poke()"
    class="mascot-peek-figure block w-[150px] origin-bottom focus:outline-none focus-visible:ring-2 focus-visible:ring-primary rounded-t-xl"
    :aria-label="open ? 'Hide Smallz’s tip' : 'Smallz has a tip — tap to see it'"
    :aria-expanded="open"
  >
    <div class="relative w-[150px]">
      <img
        src="/images/mascot/smallz.png"
        alt="Smallz, the YKS caveman mascot"
        width="150"
        height="214"
        class="block w-[150px] h-auto pointer-events-none drop-shadow-[0_8px_18px_rgba(0,0,0,0.45)]"
        decoding="async"
        loading="lazy"
        draggable="false"
      />
      <!-- Pupils overlay — same coordinate space as the PNG (741×1056). -->
      <svg
        class="absolute inset-0 w-full h-full pointer-events-none"
        viewBox="0 0 741 1056"
        aria-hidden="true"
      >
        <g class="pupil pupil-r">
          <circle cx="501" cy="285" r="19" fill="#1c140d" />
          <circle cx="495" cy="279" r="3.4" fill="#ffffff" />
        </g>
        <g class="pupil pupil-l">
          <circle cx="372" cy="284" r="13" fill="#1c140d" />
          <circle cx="367" cy="279" r="2.4" fill="#ffffff" />
        </g>
      </svg>
    </div>
  </button>
</div>

<style is:global>
  #mascot-peek .mascot-peek-figure {
    transform: translateY(78px);
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  /* peeked = revealed; the inline script also nudges it via --peek on scroll */
  #mascot-peek.is-peeked .mascot-peek-figure {
    transform: translateY(calc(26px - var(--peek, 0) * 20px));
    animation: smallzBob 4.5s ease-in-out infinite;
  }
  #mascot-peek.is-waving .mascot-peek-figure {
    animation: smallzWave 0.7s ease-in-out 2;
  }

  /* Cursor-tracking pupils — transform is set inline from JS (in image/user
     units); this just smooths the glance. */
  #mascot-peek .pupil { transition: transform 0.14s ease-out; }

  @keyframes smallzBob {
    0%, 100% { transform: translateY(calc(26px - var(--peek, 0) * 20px)) rotate(0deg); }
    50%      { transform: translateY(calc(18px - var(--peek, 0) * 20px)) rotate(-1.2deg); }
  }
  @keyframes smallzWave {
    0%, 100% { transform: translateY(calc(20px - var(--peek, 0) * 20px)) rotate(0deg); }
    30%      { transform: translateY(calc(14px - var(--peek, 0) * 20px)) rotate(-6deg); }
    70%      { transform: translateY(calc(14px - var(--peek, 0) * 20px)) rotate(4deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    #mascot-peek .mascot-peek-figure { transition: none; transform: translateY(26px); animation: none; }
    #mascot-peek.is-peeked .mascot-peek-figure { animation: none; }
    #mascot-peek.is-waving .mascot-peek-figure { animation: none; }
    #mascot-peek .pupil { transition: none; }
  }
</style>

<script is:inline>
  document.addEventListener('alpine:init', () => {
    window.Alpine.data('mascotPeek', () => ({
      open: false,
      peeked: false,
      tipIndex: 0,
      tips: [
        { tag: 'Smallz says', text: 'Ungh. Big brain start small. Tick one box today, build streak.', cta: 'OPEN HABIT TRACKER', href: '/tools/habit-tracker' },
        { tag: 'Smallz says', text: 'Focus good. One block at a time, no distraction. Smallz approve.', cta: 'START A FOCUS SPRINT', href: '/tools/focus-timer' },
        { tag: 'Smallz says', text: 'Smallz collect many guide. Most are free. Take, no signup needed.', cta: 'BROWSE THE LIBRARY', href: '/guides' },
        { tag: 'Smallz says', text: 'Free sticker drop every week. Pick one box, see what you pull.', cta: 'GO TO THE DROP', href: '/#weekly-drop' },
      ],
      get tip() { return this.tips[this.tipIndex]; },

      init() {
        const root = this.$root;
        const pupR = root.querySelector('.pupil-r');
        const pupL = root.querySelector('.pupil-l');

        // Peek in shortly after load (always reveals, even without scroll).
        setTimeout(() => { this.peeked = true; }, 900);

        // Eyes follow the cursor: aim from his face toward the pointer, clamp to
        // a unit vector so the pupils stay inside the sclera. Transforms are set
        // inline in image/user units (the SVG viewBox matches the PNG).
        const onMove = (e) => {
          const r = root.getBoundingClientRect();
          const fx = r.left + r.width * 0.5;   // face is roughly centered horizontally
          const fy = r.top + r.height * 0.32;  // ...and in the upper third
          const dx = e.clientX - fx;
          const dy = e.clientY - fy;
          const d = Math.hypot(dx, dy) || 1;
          const reach = 140; // px to mouse at which the eyes are fully deflected
          const k = Math.min(1, d / reach);
          const ex = dx / d * k;
          const ey = Math.max(-0.7, dy / d * k);
          if (pupR) pupR.style.transform = 'translate(' + (ex * 7).toFixed(2) + 'px,' + (ey * 6).toFixed(2) + 'px)';
          if (pupL) pupL.style.transform = 'translate(' + (ex * 4).toFixed(2) + 'px,' + (ey * 3.5).toFixed(2) + 'px)';
        };
        window.addEventListener('mousemove', onMove, { passive: true });

        // Peek a little higher as the page is scrolled (rAF-throttled; real
        // user scroll only — programmatic scroll may not fire here).
        let ticking = false;
        const onScroll = () => {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(() => {
            ticking = false;
            const max = (document.documentElement.scrollHeight - window.innerHeight) || 1;
            const p = Math.min(1, Math.max(0, window.scrollY / max));
            root.style.setProperty('--peek', p.toFixed(3));
          });
        };
        window.addEventListener('scroll', onScroll, { passive: true });
      },

      poke() {
        if (this.open) { this.open = false; return; }
        this.tipIndex = (this.tipIndex + 1) % this.tips.length;
        this.open = true;
        // wave
        const root = this.$root;
        root.classList.remove('is-waving');
        void root.offsetWidth; // restart animation
        root.classList.add('is-waving');
      },
    }));
  });
</script>
