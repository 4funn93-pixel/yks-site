---
/**
 * BoneDrop — "Smallz throws you a bone."
 *
 * A playful Smallz-style bone drifts around the screen on a slow wandering
 * path. Catch it (click/tap) and Smallz rewards you with a one-off discount —
 * a random 5–35% off code good across YKS *and* any YKS partner site. The code
 * is persisted (localStorage) so the catch sticks, and the bone goes quiet for
 * a cooldown so it stays a treat, not a farm. A small "saved code" chip lets
 * you reopen the reward any time during the cooldown.
 *
 * Follows the site's is:inline Alpine pattern (plain JS so the alpine:init
 * listener is registered before Alpine boots). Motion uses requestAnimationFrame
 * (fires reliably in every env, unlike scroll/IntersectionObserver). Respects
 * prefers-reduced-motion: the bone rests in a corner with a gentle pulse instead
 * of wandering.
 *
 * ── Wiring real discounts ──────────────────────────────────────────────────
 * The codes shown here are display codes by default. To make them redeemable,
 * create matching fixed discount codes in Lemon Squeezy (and each partner store)
 * and list them in `realCodes` below, keyed by percent. Any tier without a real
 * code falls back to a generated display code (still copyable, just not live).
 */

const cooldownDays = 7;
---

<div
  id="bone-drop"
  x-data="boneDrop"
  x-cloak
  class="print:hidden"
  aria-live="polite"
>
  <!-- ── The wandering bone (catchable) ─────────────────────────────── -->
  <button
    x-ref="bone"
    type="button"
    x-show="hunting"
    @click="catchBone()"
    class="bone fixed top-0 left-0 z-[125] block cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-primary rounded-full"
    aria-label="Catch the bone Smallz threw for a surprise discount"
    title="Catch me! 🦴"
  >
    <span class="bone-glow" aria-hidden="true"></span>
    <svg viewBox="0 0 72 38" width="64" height="34" aria-hidden="true" class="bone-svg">
      <path
        d="M21.49 14 L50.51 14 A9 9 0 1 1 54.88 19 A9 9 0 1 1 50.51 24 L21.49 24 A9 9 0 1 1 17.12 19 A9 9 0 1 1 21.49 14 Z"
        fill="#f2ead6" stroke="#101012" stroke-width="2.6" stroke-linejoin="round"
      />
      <!-- shine -->
      <ellipse cx="13" cy="9" rx="3" ry="2" fill="#ffffff" opacity="0.65" />
    </svg>
    <!-- sparkle that says "I'm special, click me" -->
    <svg class="bone-spark" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
      <path d="M12 2 L13.6 9.4 L21 11 L13.6 12.6 L12 20 L10.4 12.6 L3 11 L10.4 9.4 Z" fill="#c7f73e" />
    </svg>
  </button>

  <!-- ── Saved-code chip (during cooldown, when the modal is closed) ── -->
  <button
    type="button"
    x-show="hasCode && !open"
    x-cloak
    @click="open = true"
    class="fixed bottom-5 left-4 z-[125] flex items-center gap-2 rounded-full border border-primary/40 bg-bg-card/95 backdrop-blur px-3.5 py-2 text-sm shadow-xl hover:border-primary transition-colors"
    aria-label="Reopen your discount code from Smallz"
  >
    <span aria-hidden="true">🦴</span>
    <span class="font-display font-bold tabular-nums" x-text="'−' + percent + '%'"></span>
    <span class="font-mono text-[10px] tracking-wider uppercase text-text-subtle">your code</span>
  </button>

  <!-- ── Reward modal ────────────────────────────────────────────────── -->
  <div
    x-show="open"
    x-cloak
    class="fixed inset-0 z-[210] flex items-center justify-center p-5"
  >
    <div
      class="absolute inset-0 bg-black/70 backdrop-blur-sm"
      @click="open = false"
      x-show="open"
      x-transition.opacity
      aria-hidden="true"
    ></div>

    <div
      class="bone-card relative w-full max-w-md surface-card overflow-hidden p-8 text-center"
      x-show="open"
      x-transition.scale.origin.center
      role="dialog"
      aria-modal="true"
      aria-label="Smallz discount reward"
    >
      <div class="bone-confetti" aria-hidden="true"></div>
      <div class="absolute -top-20 left-1/2 -translate-x-1/2 w-[360px] h-[200px] glow-accent pointer-events-none"></div>

      <button
        @click="open = false"
        class="absolute top-3.5 right-3.5 text-text-subtle hover:text-text leading-none z-10"
        aria-label="Close"
      >✕</button>

      <div class="relative">
        <div class="text-5xl mb-3" aria-hidden="true">🦴</div>
        <div class="eyebrow mb-2">Smallz threw you a bone</div>
        <h3 class="font-display font-bold text-2xl tracking-tight">
          You caught <span class="accent-text" x-text="percent + '% off'"></span>
        </h3>
        <p class="text-sm text-text-muted leading-relaxed mt-2 max-w-xs mx-auto">
          Ungh. You catch, you save. Use this on <strong class="text-text">anything</strong> here —
          or any YKS partner site.
        </p>

        <!-- code -->
        <div class="mt-6 flex items-center gap-2 rounded-xl border border-dashed border-primary/50 bg-primary/[0.06] p-2 pl-4">
          <span class="font-mono text-lg tracking-[0.18em] text-primary flex-1 text-left select-all" x-text="code"></span>
          <button @click="copyCode()" class="btn btn-primary text-xs py-2.5 px-4 shrink-0">Copy</button>
        </div>
        <p class="font-mono text-[10px] tracking-wide text-text-subtle mt-2.5 uppercase">
          Paste at checkout · one bone per week
        </p>

        <div class="mt-6 flex flex-col sm:flex-row gap-2.5">
          <a href="/bundles" class="btn btn-primary flex-1 py-3 text-sm">Spend it on a pack</a>
          <a href="/guides" class="btn btn-secondary flex-1 py-3 text-sm">Browse the library</a>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* ---- the bone ---- */
  #bone-drop .bone {
    background: none;
    border: 0;
    padding: 6px;
    line-height: 0;
    will-change: transform;
  }
  #bone-drop .bone-svg {
    position: relative;
    z-index: 1;
    filter: drop-shadow(0 6px 10px rgba(0, 0, 0, 0.45));
    transition: transform 0.18s cubic-bezier(0.22, 1.3, 0.36, 1);
  }
  #bone-drop .bone:hover .bone-svg { transform: scale(1.16) rotate(-6deg); }
  #bone-drop .bone:active .bone-svg { transform: scale(0.92); }

  /* lime glow pulse to pull the eye */
  #bone-drop .bone-glow {
    position: absolute;
    inset: -10px;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(199, 247, 62, 0.45) 0%, rgba(199, 247, 62, 0) 70%);
    animation: boneGlow 1.8s ease-in-out infinite;
    pointer-events: none;
  }
  #bone-drop .bone-spark {
    position: absolute;
    top: -2px;
    right: 0;
    z-index: 2;
    transform-origin: center;
    animation: boneSpark 1.6s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes boneGlow {
    0%, 100% { opacity: 0.55; transform: scale(0.92); }
    50%      { opacity: 1;    transform: scale(1.08); }
  }
  @keyframes boneSpark {
    0%, 100% { opacity: 0.4; transform: scale(0.7) rotate(0deg); }
    50%      { opacity: 1;   transform: scale(1) rotate(90deg); }
  }

  /* ---- confetti burst (modal) ---- */
  #bone-drop .bone-confetti {
    position: absolute;
    top: 84px;
    left: 50%;
    width: 0;
    height: 0;
    z-index: 5;
    pointer-events: none;
  }
  #bone-drop .bone-confetti i {
    position: absolute;
    left: 0;
    top: 0;
    width: 9px;
    height: 9px;
    border-radius: 2px;
    opacity: 0;
    animation: boneConfetti 0.95s ease-out forwards;
    animation-delay: var(--d, 0s);
  }
  @keyframes boneConfetti {
    0%   { opacity: 1; transform: translate(0, 0) scale(1) rotate(0deg); }
    100% { opacity: 0; transform: translate(var(--dx), var(--dy)) scale(0.4) rotate(var(--r)); }
  }

  @media (prefers-reduced-motion: reduce) {
    #bone-drop .bone-glow { animation: none; opacity: 0.7; }
    #bone-drop .bone-spark { animation: none; opacity: 0.7; }
    #bone-drop .bone-svg { transition: none; }
    #bone-drop .bone-confetti i { display: none; }
  }
</style>

<script is:inline define:vars={{ cooldownDays }}>
  document.addEventListener('alpine:init', () => {
    window.Alpine.data('boneDrop', () => ({
      KEY: 'yks:bone',
      cooldownMs: cooldownDays * 86400000,
      // Real, redeemable codes per percent tier (create them in Lemon Squeezy /
      // partner stores, then list here). Empty → a display code is generated.
      realCodes: {},
      codePrefix: 'BONE',
      // Weighted pool — small wins common, big discounts rare. Spans 5–35%.
      tiers: [5, 5, 5, 10, 10, 10, 15, 15, 20, 20, 25, 30, 35],

      hunting: true,
      open: false,
      percent: 0,
      code: '',
      caughtAt: 0,
      _raf: null,

      get hasCode() { return !!this.code; },

      init() {
        try {
          const raw = localStorage.getItem(this.KEY);
          if (raw) {
            const d = JSON.parse(raw);
            if (d && d.code && Date.now() - d.caughtAt < this.cooldownMs) {
              this.code = d.code;
              this.percent = d.percent;
              this.caughtAt = d.caughtAt;
              this.hunting = false; // already caught this week → chip only
            }
          }
        } catch (e) { /* ignore corrupt state */ }

        if (this.hunting) this.$nextTick(() => this.startHunt());
      },

      persist() {
        try {
          localStorage.setItem(this.KEY, JSON.stringify({
            caughtAt: this.caughtAt, percent: this.percent, code: this.code,
          }));
        } catch (e) { /* storage may be unavailable */ }
      },

      startHunt() {
        const el = this.$refs.bone;
        if (!el) return;
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const BW = 76, BH = 46, pad = 18;
        const minX = pad, minY = 84;
        // Viewport can momentarily report 0 (headless/early paint) — fall back so
        // the bone is never jammed into the corner.
        const vw = () => window.innerWidth || document.documentElement.clientWidth || 1024;
        const vh = () => window.innerHeight || document.documentElement.clientHeight || 720;

        if (reduce) {
          // Rest in the top-right; gentle CSS pulse draws the eye, no drifting.
          el.style.transform = 'translate(' + (vw() - BW - 24) + 'px, 96px)';
          return;
        }

        const bounds = () => ({
          maxX: Math.max(minX + 1, vw() - BW - pad),
          // keep clear of the bottom-right corner mascot + page chrome
          maxY: Math.max(minY + 1, Math.min(vh() * 0.6, vh() - BH - 150)),
        });

        let { maxX, maxY } = bounds();
        let x = minX + Math.random() * (maxX - minX) * 0.7;
        let y = minY + Math.random() * 90;
        // Place it immediately so it's visible even if rAF never ticks
        // (some embedded/headless previews don't run animation frames).
        el.style.transform = 'translate(' + x.toFixed(1) + 'px,' + y.toFixed(1) + 'px)';
        const speed = 30; // px/s
        const ang = Math.random() * Math.PI * 2;
        let vx = Math.cos(ang) * speed;
        let vy = Math.sin(ang) * speed;
        let last = performance.now();
        const t0 = last;

        const frame = (now) => {
          if (!this.hunting) return; // caught → stop the loop
          const dt = Math.min(0.05, (now - last) / 1000);
          last = now;
          ({ maxX, maxY } = bounds());

          x += vx * dt;
          y += vy * dt;
          if (x <= minX) { x = minX; vx = Math.abs(vx); }
          if (x >= maxX) { x = maxX; vx = -Math.abs(vx); }
          if (y <= minY) { y = minY; vy = Math.abs(vy); }
          if (y >= maxY) { y = maxY; vy = -Math.abs(vy); }

          const wob = Math.sin((now - t0) / 650) * 13; // lazy tumble
          el.style.transform = 'translate(' + x.toFixed(1) + 'px,' + y.toFixed(1) + 'px) rotate(' + wob.toFixed(1) + 'deg)';
          this._raf = requestAnimationFrame(frame);
        };
        this._raf = requestAnimationFrame(frame);
      },

      makeCode(p) {
        if (this.realCodes[p]) return this.realCodes[p];
        const alphabet = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
        let r = '';
        for (let i = 0; i < 4; i++) r += alphabet[Math.floor(Math.random() * alphabet.length)];
        return this.codePrefix + p + '-' + r;
      },

      catchBone() {
        if (!this.hunting) return;
        this.hunting = false;
        if (this._raf) cancelAnimationFrame(this._raf);

        this.percent = this.tiers[Math.floor(Math.random() * this.tiers.length)];
        this.code = this.makeCode(this.percent);
        this.caughtAt = Date.now();
        this.open = true;
        this.persist();

        this.$nextTick(() => this.burst());
        if (window.showToast) window.showToast('🦴 Caught it! ' + this.percent + '% off unlocked.');
      },

      burst() {
        const host = this.$root.querySelector('.bone-confetti');
        if (!host) return;
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        const colors = ['#c7f73e', '#fb7185', '#38bdf8', '#fbbf24', '#a78bfa', '#34d399', '#f2ead6'];
        host.innerHTML = '';
        for (let i = 0; i < 28; i++) {
          const s = document.createElement('i');
          const a = Math.random() * Math.PI * 2;
          const dist = 60 + Math.random() * 130;
          s.style.setProperty('--dx', (Math.cos(a) * dist).toFixed(0) + 'px');
          s.style.setProperty('--dy', (Math.sin(a) * dist - 20).toFixed(0) + 'px');
          s.style.setProperty('--r', (Math.random() * 360).toFixed(0) + 'deg');
          s.style.setProperty('--d', (Math.random() * 0.12).toFixed(2) + 's');
          s.style.background = colors[i % colors.length];
          host.appendChild(s);
        }
      },

      copyCode() {
        const done = () => { if (window.showToast) window.showToast('Code copied — paste at checkout.'); };
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(this.code).then(done).catch(() => {});
        }
      },
    }));
  });
</script>
